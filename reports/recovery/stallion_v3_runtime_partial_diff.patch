+func _merge_static_surfaces(model: Node3D) -> void:
+	var tools: Dictionary = {}
+	var source_meshes: Array[MeshInstance3D] = []
+	for child in model.find_children("*", "MeshInstance3D", true, false):
+		var mesh_instance := child as MeshInstance3D
+		if _belongs_to_wheel(mesh_instance) or mesh_instance.mesh == null:
+			continue
+		source_meshes.append(mesh_instance)
+		var relative_transform := _transform_relative_to(mesh_instance, model)
+		for surface in mesh_instance.mesh.get_surface_count():
+			var category := _surface_category(mesh_instance.name, surface)
+			if not tools.has(category):
+				var surface_tool := SurfaceTool.new()
+				surface_tool.begin(Mesh.PRIMITIVE_TRIANGLES)
+				tools[category] = surface_tool
+			(tools[category] as SurfaceTool).append_from(mesh_instance.mesh, surface, relative_transform)
+	var merged_root := Node3D.new()
+	merged_root.name = "RuntimeMergedStatic"
+	model.add_child(merged_root)
+	for category in tools:
+		var merged := MeshInstance3D.new()
+		merged.name = "Merged_%s" % category
+		merged.mesh = (tools[category] as SurfaceTool).commit()
+		merged.material_override = _material_for(category, "rally_sand")
+		merged_root.add_child(merged)
+	for mesh_instance in source_meshes:
+		var parent := mesh_instance.get_parent()
+		parent.remove_child(mesh_instance)
+		mesh_instance.free()
+
+func _belongs_to_wheel(node: Node) -> bool:
+	var current := node.get_parent()
+	while current != null and current != self:
+		if bool(current.get_meta("vehicle_wheel", false)):
+			return true
+		current = current.get_parent()
+	return false
+
+func _transform_relative_to(node: Node3D, ancestor: Node3D) -> Transform3D:
+	var result := node.transform
+	var current := node.get_parent()
+	while current != null and current != ancestor:
+		if current is Node3D:
+			result = (current as Node3D).transform * result
+		current = current.get_parent()
+	return result
+
